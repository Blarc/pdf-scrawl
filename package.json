{
  "name": "pdf-scrawl",
  "private": true,
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "dev:frontend": "bun run --filter=frontend dev",
    "dev:server": "bun run --filter=server dev",
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:frontend\"",
    "start": "bun run server start",
    "test": "export TMPDIR=$(pwd) && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.9",
    "tailwindcss": "3.4.17"
  }
}
